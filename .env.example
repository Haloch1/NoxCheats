# ==========================================================================
# Nox Cheats backend configuration.
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# The server runs without these, but auth/checkout stay disabled until set.
# ==========================================================================

# ---- Server ----
PORT=3000
# Public base URL of the site (used for Stripe + Discord redirect URLs).
SITE_URL=http://localhost:3000
# Long random string used to sign/derive Discord account passwords. Keep secret.
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Supabase (Project Settings > API) ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Anon/publishable key — safe to expose to the browser.
SUPABASE_ANON_KEY=
# Service-role/secret key — SERVER ONLY. Never send to the browser.
SUPABASE_SERVICE_KEY=

# ---- Stripe (Developers > API keys) ----
STRIPE_SECRET_KEY=
# From the webhook endpoint you create for POST /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# ---- Discord OAuth (Developer Portal > your app > OAuth2) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must exactly match a redirect URI you add in the Discord app:
#   {SITE_URL}/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
# Optional: bot token to DM license keys to buyers AND run the two-way support desk.
# The bot needs the "Message Content Intent" enabled (Developer Portal > Bot),
# and must be invited to your server with permission to create/read threads.
DISCORD_BOT_TOKEN=
# Two-way support desk: ID of the text channel where each web ticket opens a
# Discord thread. Staff replies in that thread sync back to the site.
# (Enable Developer Mode in Discord, right-click the channel > Copy Channel ID.)
DISCORD_DESK_CHANNEL_ID=
# Purchases channel: create a webhook on that channel and paste its URL here.
# Every paid order is posted to it.
DISCORD_ORDER_WEBHOOK_URL=

# ---- Google OAuth (Google Cloud Console > Credentials > OAuth client) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI: {SITE_URL}/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ---- Promo codes ----
# Comma-separated CODE:percent pairs, e.g. "WELCOME:10,SAVE20:20".
# Codes stay server-side; the browser only learns whether a code is valid.
PROMO_CODES=

# ---- Bootstrap ----
# Comma-separated emails auto-granted the "admin" role on first sign-in.
ADMIN_EMAILS=

# Admin panel access. "true" (default) lets ANYONE open /admin and its APIs —
# handy while building/demoing. Set to "false" to require the admin role.
ADMIN_OPEN=true

# ---- Dev testing ----
# DEV_LOGIN=true shows a one-click "Dev test login" button on the account page
# (and enables /api/dev/login) so you can test signed-in features without real
# auth. Leave blank/false in production and in any copy you share.
DEV_LOGIN=
